{
  "manifest_version": 3,
  "name": "Busca CEP",
  "version": "2.0",
  "description": "Extensao para buscar CEP e endereco usando o servico ViaCEP.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "256x256bb.png",
      "48": "256x256bb.png",
      "128": "256x256bb.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "icons": {
    "16": "256x256bb.png",
    "48": "256x256bb.png",
    "128": "256x256bb.png"
  }
}
